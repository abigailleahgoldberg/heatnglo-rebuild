---
import '../styles/global.css';
import TopUtilityStrip from '@components/global/TopUtilityStrip.astro';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';
import StickyCta from '@components/global/StickyCta.astro';
import { allLocaleAlternates, detectLocale, LOCALE_HREFLANG } from '@lib/localeUrls';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  structuredData?: object;
  hideStickyCta?: boolean;
}

const {
  title,
  description,
  ogImage = 'https://heatnglo.com/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  noIndex = false,
  structuredData,
  hideStickyCta = false,
} = Astro.props;

const pathname = Astro.url.pathname;
const currentLocale = detectLocale(pathname);
const htmlLang = LOCALE_HREFLANG[currentLocale];
const canonical = canonicalUrl ?? new URL(pathname, Astro.site).toString();
const alternates = allLocaleAlternates(pathname);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`https://heatnglo.com${pathname.replace(/^\/(es|en-ca|fr-ca)/, '')}`} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={htmlLang.replace('-', '_')} />
    <meta property="og:site_name" content="Heat & Glo" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#1a1a1a" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=yes" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap"
    />

    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <TopUtilityStrip />
    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    {!hideStickyCta && <StickyCta />}

    <script>
      if (typeof window !== 'undefined' && (window as Window & { inEditorMode?: boolean }).inEditorMode) {
        import('../cloudcannon/registerComponents').catch((err) => {
          console.warn('CloudCannon registerComponents failed to load:', err);
        });
      }
    </script>
  </body>
</html>
