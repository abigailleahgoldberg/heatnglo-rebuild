---
/*
  Component: LoveYourFireplaceBlock
  Mockup ref: <section class="feature" id="promo">
  Metaphor:   Love Your Fireplace Again
*/
import { sectionClasses, btnClasses, type BgVariant, type Alignment, type Density, type BtnVariant } from '@lib/blockVariants';

interface Props {
  eyebrow?: string;
  heading: string;
  heading_em?: string;
  paragraph_1?: string;
  paragraph_2?: string;
  cta_text?: string;
  cta_href?: string;
  cta_variant?: BtnVariant;
  media_image?: string;
  media_image_alt?: string;
  media_position?: 'left' | 'right';
  bg_variant?: BgVariant;
  alignment?: Alignment;
  density?: Density;
  hidden_on_mobile?: boolean;
}

const {
  eyebrow = '',
  heading,
  heading_em = '',
  paragraph_1 = '',
  paragraph_2 = '',
  cta_text = '',
  cta_href = '/contact/',
  cta_variant,
  media_image = '',
  media_image_alt = '',
  media_position = 'right',
  bg_variant,
  alignment,
  density,
  hidden_on_mobile,
} = Astro.props;

const sectionClass = sectionClasses({ bg_variant, alignment, density, hidden_on_mobile }, 'feature');
const btnClass = btnClasses(cta_variant, 'ink');
const reverse = media_position === 'left';
---
<section id="promo" class={sectionClass} aria-labelledby="love-your-fireplace-heading">
  <div class="container">
    <div class:list={['feature__row', reverse && 'feature__row--reverse']}>
      <div class="feature__copy">
        {eyebrow && (
          <span class="feature__eyebrow" data-editable="text" data-prop="eyebrow">{eyebrow}</span>
        )}
        <h2 id="love-your-fireplace-heading" class="feature__title">
          <span data-editable="text" data-prop="heading">{heading}</span>{' '}
          {heading_em && <em data-editable="text" data-prop="heading_em">{heading_em}</em>}
        </h2>
        <div class="h2-rule"></div>
        {paragraph_1 && <p data-editable="text" data-prop="paragraph_1" data-type="block">{paragraph_1}</p>}
        {paragraph_2 && <p data-editable="text" data-prop="paragraph_2" data-type="block">{paragraph_2}</p>}
        {cta_text && (
          <a class={btnClass} href={cta_href} data-editable="text" data-prop="cta_text">{cta_text}</a>
        )}
      </div>
      {media_image && (
        <div class="feature__media">
          <img
            src={media_image}
            alt={media_image_alt}
            loading="lazy"
            width="1000"
            height="750"
            data-editable="image"
            data-prop-src="media_image"
            data-prop-alt="media_image_alt"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style is:global>
  .feature { padding: 70px 0; }
  .feature__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
    align-items: center;
  }
  @media (min-width: 769px) {
    .feature__row { grid-template-columns: 1.05fr 1fr; gap: 56px; }
    .feature__row--reverse { direction: rtl; }
    .feature__row--reverse > * { direction: ltr; }
  }
  .feature__eyebrow {
    display: inline-block;
    font-family: var(--display);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--orange-2);
    margin-bottom: 12px;
  }
  .feature__title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0;
  }
  .feature__title em { font-style: italic; color: var(--orange-2); }
  .feature p {
    color: var(--ink-2);
    margin: 0 0 16px;
    line-height: 1.7;
  }
  .feature__media img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 18px 40px rgba(0,0,0,0.10);
  }
</style>
