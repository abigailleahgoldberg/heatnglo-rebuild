---
/*
  Component: ProAdvantageBlock
  Mockup ref: <section class="feature feature--alt" id="proadvantage">
  Metaphor:   ProAdvantage Trade Strip
*/
import { sectionClasses, btnClasses, type BgVariant, type Alignment, type Density, type BtnVariant } from '@lib/blockVariants';

interface Props {
  eyebrow?: string;
  heading: string;
  heading_em?: string;
  paragraph_1?: string;
  paragraph_2?: string;
  cta_text?: string;
  cta_href?: string;
  cta_variant?: BtnVariant;
  media_image?: string;
  media_image_alt?: string;
  bg_variant?: BgVariant;
  alignment?: Alignment;
  density?: Density;
  hidden_on_mobile?: boolean;
}

const {
  eyebrow = 'For Builders & Designers',
  heading,
  heading_em = '',
  paragraph_1 = '',
  paragraph_2 = '',
  cta_text = 'Join Today',
  cta_href = '/pro/proadvantage/',
  cta_variant,
  media_image = '',
  media_image_alt = '',
  bg_variant = 'cream',
  alignment,
  density,
  hidden_on_mobile,
} = Astro.props;

const sectionClass = sectionClasses({ bg_variant, alignment, density, hidden_on_mobile }, 'feature feature--alt');
const btnClass = btnClasses(cta_variant, 'ink');
---
<section id="proadvantage" class={sectionClass} aria-labelledby="proadvantage-heading">
  <div class="container">
    <div class="feature__row feature__row--reverse">
      <div class="feature__copy">
        {eyebrow && (
          <span class="feature__eyebrow" data-editable="text" data-prop="eyebrow">{eyebrow}</span>
        )}
        <h2 id="proadvantage-heading" class="feature__title">
          <span data-editable="text" data-prop="heading">{heading}</span>{' '}
          {heading_em && <em data-editable="text" data-prop="heading_em">{heading_em}</em>}
        </h2>
        <div class="h2-rule"></div>
        {paragraph_1 && <p data-editable="text" data-prop="paragraph_1" data-type="block">{paragraph_1}</p>}
        {paragraph_2 && <p data-editable="text" data-prop="paragraph_2" data-type="block">{paragraph_2}</p>}
        {cta_text && (
          <a class={btnClass} href={cta_href} data-editable="text" data-prop="cta_text">{cta_text}</a>
        )}
      </div>
      {media_image && (
        <div class="feature__media">
          <img
            src={media_image}
            alt={media_image_alt}
            loading="lazy"
            width="900"
            height="675"
            data-editable="image"
            data-prop-src="media_image"
            data-prop-alt="media_image_alt"
          />
        </div>
      )}
    </div>
  </div>
</section>
