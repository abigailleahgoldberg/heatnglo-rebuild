---
/*
  Component: QuoteBlock
  Mockup ref: <section class="quote" id="why">
  Metaphor:   Owner Quote
*/
import { sectionClasses, type BgVariant, type Alignment, type Density } from '@lib/blockVariants';

interface Props {
  stars?: number;
  quote_body: string;
  attribution_name?: string;
  attribution_meta?: string;
  bg_variant?: BgVariant;
  alignment?: Alignment;
  density?: Density;
  hidden_on_mobile?: boolean;
}

const {
  stars = 5,
  quote_body,
  attribution_name = '',
  attribution_meta = '',
  bg_variant = 'cream',
  alignment = 'center',
  density,
  hidden_on_mobile,
} = Astro.props;

const sectionClass = sectionClasses({ bg_variant, alignment, density, hidden_on_mobile }, 'quote');
const starsString = '★ '.repeat(Math.max(0, Math.min(5, stars))).trim();
---
<section id="why" class={sectionClass} aria-label="Customer testimonial">
  <div class="container">
    <div class="quote__star" aria-hidden="true">{starsString}</div>
    <blockquote class="quote__body" data-editable="text" data-prop="quote_body" data-type="block">
      "{quote_body}"
    </blockquote>
    {(attribution_name || attribution_meta) && (
      <p class="quote__attribution">
        {attribution_name && <strong data-editable="text" data-prop="attribution_name">{attribution_name}</strong>}
        {attribution_meta && (
          <span> · <span data-editable="text" data-prop="attribution_meta">{attribution_meta}</span></span>
        )}
      </p>
    )}
  </div>
</section>

<style is:global>
  .quote { padding: 80px 0; background: var(--bone); text-align: center; }
  .quote__star {
    color: #d89b4a;
    font-size: 18px;
    letter-spacing: 0.20em;
    margin-bottom: 20px;
  }
  .quote__body {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 820px;
    margin: 0 auto 22px;
    quotes: none;
  }
  .quote__attribution {
    font-family: var(--display);
    font-size: 13.5px;
    color: var(--steel);
    letter-spacing: 0.04em;
    margin: 0;
  }
  .quote__attribution strong {
    color: var(--ink);
    font-weight: 700;
    margin-right: 4px;
  }
</style>
