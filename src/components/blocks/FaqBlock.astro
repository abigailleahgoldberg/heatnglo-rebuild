---
/*
  Component: FaqBlock
  Mockup ref: <section class="faq">
  Metaphor:   Common Questions — Showroom-Q&A register
*/
import { sectionClasses, type BgVariant, type Alignment, type Density } from '@lib/blockVariants';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  heading_em?: string;
  items?: FaqItem[];
  bg_variant?: BgVariant;
  alignment?: Alignment;
  density?: Density;
  hidden_on_mobile?: boolean;
}

const {
  eyebrow = 'Common Questions',
  heading,
  heading_em = '',
  items = [],
  bg_variant,
  alignment = 'center',
  density,
  hidden_on_mobile,
} = Astro.props;

const sectionClass = sectionClasses({ bg_variant, alignment, density, hidden_on_mobile }, 'faq');
---
<section class={sectionClass} aria-labelledby="faq-heading">
  <div class="container">
    <div class="faq__head">
      {eyebrow && <span class="eyebrow" data-editable="text" data-prop="eyebrow">{eyebrow}</span>}
      <h2 id="faq-heading" class="faq__title">
        <span data-editable="text" data-prop="heading">{heading}</span>{' '}
        {heading_em && <em data-editable="text" data-prop="heading_em">{heading_em}</em>}
      </h2>
      <div class="h2-rule"></div>
    </div>
    <div class="faq__list" data-editable="array" data-prop="items">
      {items.map((item) => (
        <details class="faq__item" data-editable="array-item">
          <summary data-editable="text" data-prop="question">{item.question}</summary>
          <div class="faq__item-body" data-editable="text" data-prop="answer" data-type="block">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .faq { padding: 70px 0; background: var(--paper); }
  .faq__head { max-width: 720px; margin: 0 auto 36px; }
  .eyebrow {
    display: inline-block;
    font-family: var(--display);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--orange-2);
  }
  .faq__title {
    font-family: var(--display);
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.018em;
    margin: 12px 0 0;
    color: var(--ink);
  }
  .faq__title em { font-style: italic; color: var(--orange-2); }
  .faq__list {
    max-width: 820px;
    margin: 0 auto;
    text-align: left;
  }
  .faq__item {
    border-bottom: 1px solid var(--rule);
    padding: 18px 0;
  }
  .faq__item summary {
    cursor: pointer;
    font-family: var(--display);
    font-weight: 600;
    font-size: 16px;
    color: var(--ink);
    padding-right: 28px;
    list-style: none;
    position: relative;
  }
  .faq__item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 22px;
    font-weight: 300;
    color: var(--orange-2);
    transition: transform 0.18s ease;
  }
  .faq__item[open] summary::after { content: '–'; }
  .faq__item-body {
    margin-top: 12px;
    color: var(--ink-2);
    line-height: 1.7;
  }
</style>
