---
import type { BtnVariant } from '@lib/blockVariants';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: BtnVariant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
  rel?: string;
  target?: string;
}

const {
  variant = 'orange',
  size = 'md',
  href,
  type = 'button',
  fullWidth = false,
  class: className = '',
  ariaLabel,
  rel,
  target,
} = Astro.props;

const sizeClass = size === 'sm' ? 'btn--sm' : size === 'lg' ? 'btn--lg' : '';
const variantClass = `btn--${variant}`;

// .btn classes live in src/styles/global.css per Phase 4 §4a — used by string-name across blocks.
---

{href ? (
  <a
    href={href}
    aria-label={ariaLabel}
    rel={rel}
    target={target}
    class:list={['btn', variantClass, sizeClass, fullWidth && 'btn--block', className]}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    aria-label={ariaLabel}
    class:list={['btn', variantClass, sizeClass, fullWidth && 'btn--block', className]}
  >
    <slot />
  </button>
)}

<style is:global>
  .btn--sm    { padding: 9px 14px; font-size: 12px; }
  .btn--lg    { padding: 18px 28px; font-size: 14px; }
  .btn--block { width: 100%; justify-content: center; }
</style>
