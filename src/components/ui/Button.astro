---
type Variant = 'orange' | 'orange-outline' | 'ink' | 'ghost';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
  rel?: string;
  target?: string;
}

const {
  variant = 'orange',
  size = 'md',
  href,
  type = 'button',
  fullWidth = false,
  class: className = '',
  ariaLabel,
  rel,
  target,
} = Astro.props;

const sizeClass = size === 'sm' ? 'btn--sm' : size === 'lg' ? 'btn--lg' : '';
const variantClass = `btn--${variant}`;
---

{href ? (
  <a
    href={href}
    aria-label={ariaLabel}
    rel={rel}
    target={target}
    class:list={['btn', variantClass, sizeClass, fullWidth && 'btn--block', className]}
  >
    <slot />
  </a>
) : (
  <button
    type={type}
    aria-label={ariaLabel}
    class:list={['btn', variantClass, sizeClass, fullWidth && 'btn--block', className]}
  >
    <slot />
  </button>
)}

<style is:global>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    padding: 14px 22px;
    border-radius: 4px;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  .btn--sm { padding: 9px 14px; font-size: 12px; }
  .btn--lg { padding: 18px 28px; font-size: 14px; }
  .btn--block { width: 100%; justify-content: center; }

  .btn--ink { background: var(--ink); color: #fff; }
  .btn--ink:hover { background: var(--orange-2); transform: translateY(-1px); }

  .btn--orange { background: var(--orange-2); color: #fff; box-shadow: 0 4px 12px rgba(196,74,8,0.30); }
  .btn--orange:hover { background: var(--orange-3); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(196,74,8,0.40); }

  .btn--orange-outline { background: var(--paper); color: var(--orange-2); border: 2px solid var(--orange-2); padding: 12px 20px; }
  .btn--orange-outline:hover { background: var(--orange-2); color: #fff; }

  .btn--ghost { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); padding: 12px 20px; }
  .btn--ghost:hover { background: var(--ink); color: #fff; }
</style>
